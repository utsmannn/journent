# journent env — copy to .env, fill in for your environment.

# Public base URL (used for OAuth redirect + absolute links).
JOURNENT_BASE_URL=https://journent.com

# Bind address inside the container.
JOURNENT_BIND=0.0.0.0:8080

# Port binding on the host (for docker-compose). Defaults to 127.0.0.1:8080.
# Override to expose on a specific interface, e.g. for a Cloudflare tunnel:
#   JOURNENT_BIND_HOST=100.64.0.1
#   JOURNENT_BIND_PORT=8089
JOURNENT_BIND_HOST=127.0.0.1
JOURNENT_BIND_PORT=8080

# Database — Postgres. In docker-compose there is a `db` service
# (postgres:16-alpine). Hostname `db` = service name on the compose network.
JOURNENT_DB_URL=postgres://journent:journent@db:5432/journent
POSTGRES_PASSWORD=journent

# Google OAuth. Leave empty = STUB mode (simulated Google login).
# Stub mode: login simulated via /dev/login-stub?email=...&sub=...
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JOURNENT_OAUTH_STUB=true

# Session signing key (generate: openssl rand -base64 48).
JOURNENT_SESSION_KEY=change-me-to-something-long-and-random-please-yes-really

# Default per-agent key prefix (cosmetic; key = <prefix>_<32 hex>).
JOURNENT_KEY_PREFIX=jrn

# Log
RUST_LOG=journent=info,tower_http=info,sqlx=warn
